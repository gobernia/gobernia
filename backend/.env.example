# ── APP ──────────────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=genera-una-clave-segura-aqui

# ── DATABASE (Supabase) ───────────────────────────────────────────────────────
# Obtén estas URLs en: Supabase Dashboard → Project → Settings → Database
#
# Conexión directa (dev / Alembic migrations):
#   Host:     db.<PROJECT_REF>.supabase.co  Port: 5432
# Connection pooler Transaction mode (producción, FastAPI):
#   Host:     aws-0-<REGION>.pooler.supabase.com  Port: 6543
#
# IMPORTANTE: El pooler (puerto 6543) requiere ?pgbouncer=true en asyncpg
# y statement_cache_size=0 — ya está configurado en db/session.py

# Para desarrollo puedes usar la conexión directa en ambas:
DATABASE_URL=postgresql+asyncpg://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# ¿Estás usando el pooler (puerto 6543)? → pon USE_POOLER=true
USE_POOLER=false

# ── AUTH (Clerk — https://dashboard.clerk.com) ────────────────────────────────
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_JWKS_URL=https://<tu-clerk-domain>/.well-known/jwks.json

# ── AI (Anthropic — https://console.anthropic.com) ────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL=claude-sonnet-4-6

# ── STORAGE (AWS S3) ──────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_DOCUMENTS=gobernia-documents

# ── REDIS / CELERY ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000"]
